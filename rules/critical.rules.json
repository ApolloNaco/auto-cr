  {
    "rule_id": "java_sql_concat",
    "title": "疑似 SQL 字符串拼接（潜在注入风险）",
    "severity": "critical",
    "category": "security",
    "scope": "java",
    "trigger": {
      "type": "diffRegex",
      "pattern": "(select|update|delete|insert)\\\\b[^\\\"]*\\\\\"\\\\s*\\\\+|\\\\+\\\\s*\\\\\"\\\\s*(where|and|or)\\\\b",
      "flags": "i",
      "addedLinesOnly": false
    },
    "evidence": { "requireSnippet": true, "maxSnippetLines": 8 },
    "suggestion": "改为参数化查询/预编译语句；禁止拼接用户可控字段进入 SQL。"
  },
  {
    "rule_id": "java_redundant_if_else_return_boolean",
    "title": "冗余 if/else：两分支仅返回 true/false（可简化）",
    "severity": "critical",
    "category": "logic",
    "scope": "java",
    "trigger": {
      "type": "javaAstQuery",
      "query": "(\n+  (if_statement\n+    condition: (_) @cond\n+    consequence: (return_statement (true))\n+    alternative: (else_clause (return_statement (false)))\n+  ) @hit\n+)\n+(\n+  (if_statement\n+    condition: (_) @cond\n+    consequence: (return_statement (false))\n+    alternative: (else_clause (return_statement (true)))\n+  ) @hit\n+)"
    },
    "evidence": { "requireSnippet": true, "maxSnippetLines": 8 },
    "suggestion": "可简化：`if (cond) return true; else return false;` → `return cond;`；反之 → `return !cond;`。同时注意 cond 是否有副作用。"
  },
  {
    "rule_id": "properties_sensitive_key",
    "title": ".properties 出现疑似敏感 key（password/secret/token 等）",
    "severity": "critical",
    "category": "security",
    "scope": "properties",
    "trigger": {
      "type": "propertiesKeyRegex",
