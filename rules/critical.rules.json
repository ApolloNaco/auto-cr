[
  {
    "rule_id": "java_empty_catch_all",
    "title": "catch(Exception/Throwable) 为空或仅打印日志（可能吞异常）",
    "severity": "critical",
    "category": "logic",
    "scope": "java",
    "trigger": {
      "type": "javaAstQuery",
      "query": "(\n+  (catch_clause\n+    (catch_formal_parameter\n+      (type_identifier) @t\n+    )\n+    (block) @hit\n+  )\n+  (#match? @t \"^(Exception|Throwable)$\")\n+)"
    },
    "evidence": { "requireSnippet": true, "maxSnippetLines": 6 },
    "suggestion": "不要吞异常；至少记录关键上下文并重新抛出或转换为业务异常。"
  },
  {
    "rule_id": "java_runtime_exec",
