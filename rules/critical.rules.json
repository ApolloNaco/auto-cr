      "type": "diffRegex",
      "pattern": "\\\\bRuntime\\\\.getRuntime\\\\(\\\\)\\\\.exec\\\\s*\\\\(|\\\\bnew\\\\s+ProcessBuilder\\\\s*\\\\(",
